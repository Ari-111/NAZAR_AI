# Supabase Configuration
NEXT_PUBLIC_SITE_URL=https://hawkwatch.vercel.app
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI API Keys
GOOGLE_API_KEY=your_google_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Email Notifications (Resend)
RESEND_API_KEY=your_resend_api_key

# Telegram Notifications
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Get your chat ID by messaging @userinfobot or @getidsbot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Twilio WhatsApp Notifications
# Twilio Account SID and Auth Token from Twilio Console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio WhatsApp-enabled number (or sandbox number)
TWILIO_WHATSAPP_FROM=+14155238886
# Destination WhatsApp number for alerts
TWILIO_WHATSAPP_TO=+1234567890

# Expo Mobile Configuration (for mobile app)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key